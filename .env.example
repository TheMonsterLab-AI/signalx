# SignalX Platform — Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_PROVIDER="postgresql"
# Production: postgresql://user:password@host:5432/signalx
# Local dev:  file:./dev.db   (SQLite, change provider to "sqlite")
DATABASE_URL="postgresql://signalx:password@localhost:5432/signalx_db"

# ── Encryption (generate with: openssl rand -hex 32) ──────────────────────────
# CRITICAL: Rotate these on first deploy. Losing these = losing encrypted data.
ENCRYPTION_KEY="your-64-char-hex-key-here-generate-with-openssl-rand-hex-32"
HMAC_SECRET="your-128-char-hex-key-here-generate-with-openssl-rand-hex-64"

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://signalx.io"
NEXT_PUBLIC_APP_NAME="SignalX"
NODE_ENV="development"

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS="https://signalx.io,https://admin.signalx.io"

# ── AI APIs (ANN Engine) ───────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="AIza..."
# Llama via Together AI or Replicate
TOGETHER_API_KEY="..."

# ── File Storage ───────────────────────────────────────────────────────────────
# Production: use S3/R2 for encrypted file storage
# Local dev: files stored in /tmp/signalx-uploads/
STORAGE_PROVIDER="local"  # "s3" | "r2" | "local"
STORAGE_BUCKET="signalx-evidence"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-northeast-2"
# OR Cloudflare R2:
R2_ENDPOINT=""
R2_ACCESS_KEY=""
R2_SECRET_KEY=""

# ── Email (Distribution) ──────────────────────────────────────────────────────
EMAIL_PROVIDER="resend"  # "resend" | "postmark" | "ses"
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@signalx.io"

# ── Job Queue (ANN Processing) ────────────────────────────────────────────────
# Production: use BullMQ + Redis, or Trigger.dev
QUEUE_URL=""
QUEUE_SECRET=""
REDIS_URL="redis://localhost:6379"

# ── Webhooks ────────────────────────────────────────────────────────────────────
WEBHOOK_SECRET="generate-random-secret-here"

# ── Rate Limiting ──────────────────────────────────────────────────────────────
# For production, use Redis-backed rate limiting (Upstash)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Monitoring ─────────────────────────────────────────────────────────────────
SENTRY_DSN=""
